{
    "name": "maguto/dilovod-sdk",
    "description": "PHP SDK for Dilovod API — Ukrainian online accounting and reporting service",
    "keywords": ["dilovod", "діловод", "api", "sdk", "accounting", "ukraine", "opencart", "e-commerce"],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Maguto",
            "email": "main@maguto.tech",
            "homepage": "https://maguto.tech"
        }
    ],
    "support": {
        "issues": "https://github.com/magutodev/dilovod-php-sdk/issues",
        "source": "https://github.com/magutodev/dilovod-php-sdk"
    },
    "require": {
        "php": "^8.2",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.1 || ^2.0",
        "psr/log": "^2.0 || ^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "guzzlehttp/guzzle": "^7.0",
        "nyholm/psr7": "^1.8",
        "php-http/mock-client": "^1.6"
    },
    "suggest": {
        "guzzlehttp/guzzle": "PSR-18/PSR-17 HTTP client implementation (recommended)",
        "nyholm/psr7": "Lightweight PSR-7/PSR-17 implementation",
        "symfony/http-client": "Alternative PSR-18 HTTP client (Symfony ecosystem)"
    },
    "autoload": {
        "psr-4": {
            "Maguto\\Dilovod\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Maguto\\Dilovod\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "phpunit --no-coverage",
        "test:unit": "phpunit --testsuite=unit --no-coverage",
        "test:integration": "phpunit --testsuite=integration --no-coverage",
        "test:coverage": "phpunit --coverage-html=coverage",
        "analyse": "phpstan analyse",
        "cs:check": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "check": [
            "@cs:check",
            "@analyse",
            "@test:unit"
        ]
    }
}
